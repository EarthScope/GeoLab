# Makefile — geolab build workflow (linux/amd64)
#
# Files:
#   environment.yml    conda packages (source of truth)
#   requirements.txt   pip packages (source of truth)
#   conda-lock.yml     generated by `make lock`
#
# Usage:
#   make lock     # regenerate conda-lock.yml from environment.yml
#   make build    # build the image (assumes conda-lock.yml exists)
#   make run      # run jupyterlab locally on port 8888
#   make shell    # open a shell in a fresh container

IMAGE  ?= jupyter-geolab
TAG    ?= latest

.PHONY: lock build run shell clean

lock:
	conda-lock lock \
	    --file environment.yml \
	    --platform linux-64 \
	    --lockfile conda-lock.yml

build:
	docker build --platform linux/amd64 -t $(IMAGE):$(TAG) .

run:
	docker run --rm --platform linux/amd64 -p 8888:8888 \
	    -e JUPYTER_TOKEN="" \
	    -v $(PWD):/home/jovyan/work \
	    $(IMAGE):$(TAG)

shell:
	docker run --rm -it --platform linux/amd64 $(IMAGE):$(TAG) bash -l

clean:
	docker rmi $(IMAGE):$(TAG) || true