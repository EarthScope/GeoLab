# syntax=docker/dockerfile:1
# ──────────────────────────────────────────────────────────────
# geolab-slim — Jupyter base-notebook + a new `geolab` conda env
# that is the active environment everywhere:
#   - Jupyter server runs from geolab (via PATH + before-notebook hook)
#   - Notebook launcher defaults to geolab's python3 kernel
#   - Terminals auto-activate geolab on start
#
# Build:
#   docker build --platform linux/amd64 -t geolab-slim .
# ──────────────────────────────────────────────────────────────
# FROM quay.io/jupyter/base-notebook:python-3.13
FROM pangeo/base-notebook

LABEL org.opencontainers.image.title="geolab-slim" \
      org.opencontainers.image.authors="sophia.parafina@earthscope.org"

USER root

# Compilers + git for any pip packages that build from source.
RUN apt-get update --quiet && \
    apt-get install --quiet --yes --no-install-recommends \
        build-essential \
        git && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# ── 1. Create the geolab env from environment.yml ────────────
COPY environment.yml /tmp/environment.yml
RUN --mount=type=cache,target=/opt/conda/pkgs,uid=1000,gid=100 \
    --mount=type=cache,target=/root/.cache/pip \
    mamba env create --name geolab --file /tmp/environment.yml && \
    rm /tmp/environment.yml

# ── 2. Register geolab as a system-wide kernel ───────────────
# --prefix=${CONDA_DIR} writes the kernelspec to
# /opt/conda/share/jupyter/kernels/geolab so it's discoverable by
# any Jupyter in the container. The kernel.json inside points at
# /opt/conda/envs/geolab/bin/python, so the kernel still runs in
# geolab. Verify discovery in the same RUN so the build fails loudly
# if anything is wrong.
RUN /opt/conda/envs/geolab/bin/python -m ipykernel install \
        --prefix="${CONDA_DIR}" \
        --name geolab \
        --display-name "geolab" && \
    rm -rf "${CONDA_DIR}/share/jupyter/kernels/python3" && \
    jupyter kernelspec list | grep -q geolab

# ── 3. Process-wide environment ──────────────────────────────
# - MAMBA_ROOT_PREFIX silences the "not set" warning from mamba.sh
# - PATH puts geolab's bin first so `jupyter`, `python`, `pip`
#   resolve to geolab from any process in the container.
ENV MAMBA_ROOT_PREFIX=${CONDA_DIR} \
    CONDA_DEFAULT_ENV=geolab \
    PATH=/opt/conda/envs/geolab/bin:${PATH}

# ── 4. Activate geolab for the Jupyter server itself ─────────
# The base image sources every *.sh in /usr/local/bin/before-notebook.d/
# before starting Jupyter. Running `conda activate` there gives the
# server a fully activated env, including activate.d scripts (GDAL_DATA,
# PROJ_DATA, etc.) that conda packages rely on.
RUN cat > /usr/local/bin/before-notebook.d/00-activate-geolab.sh <<'EOF'
. /opt/conda/etc/profile.d/conda.sh
conda activate geolab
EOF
RUN chmod +x /usr/local/bin/before-notebook.d/00-activate-geolab.sh

# ── 5. JupyterLab settings overrides ─────────────────────────
# Picked up automatically by JupyterLab as long as the file lives at
# <prefix>/share/jupyter/lab/settings/overrides.json. The settings
# inside take precedence over each user's preferences.
RUN mkdir -p /opt/conda/envs/geolab/share/jupyter/lab/settings
# COPY overrides.json /opt/conda/envs/geolab/share/jupyter/lab/settings/overrides.json
COPY overrides.json /opt/conda/lib/python3.13/site-packages/jupyterlab_server/test_data/app-settings/overrides.json

# Server-side default for notebooks opened without a kernel binding.
RUN printf "\nc.MappingKernelManager.default_kernel_name = 'geolab'\nc.MultiKernelManager.default_kernel_name = 'geolab'\n" \
        >> /etc/jupyter/jupyter_server_config.py

# ── 6. Interactive shell activation (terminal, docker exec) ──
# /etc lives outside /home/jovyan and survives runtime overlays.
RUN cat > /etc/profile.d/00-activate-geolab.sh <<'EOF'
case $- in
    *i*) ;;
    *) return 0 2>/dev/null || exit 0 ;;
esac
. /opt/conda/etc/profile.d/conda.sh
conda activate geolab
EOF

RUN echo '[ -f /etc/profile.d/00-activate-geolab.sh ] && . /etc/profile.d/00-activate-geolab.sh' \
        >> /etc/bash.bashrc && \
    printf "\nc.ServerApp.terminado_settings = {'shell_command': ['/bin/bash', '-l']}\n" \
        >> /etc/jupyter/jupyter_server_config.py

# ── 7. Permissions ───────────────────────────────────────────
RUN fix-permissions "${CONDA_DIR}" && \
    fix-permissions "/home/jovyan"

USER jovyan
WORKDIR /home/jovyan/work
EXPOSE 8888

# Inherit ENTRYPOINT and CMD from base image (tini + start-notebook.py).